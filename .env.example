# AION — plantilla de configuración local.
# Copia a `.env` y rellena tus valores. El `.env` real NUNCA se versiona.

# --- Seguridad ---
AION_JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
# Clave de firma de licencias (hex de 32 bytes). Si se omite, se genera y persiste
# en data/license_signing_key.hex.
# AION_LICENSE_KEY=

# --- Billing (Stripe, modo test) ---
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# --- Persistencia (cuando uses Postgres en vez del store en memoria) ---
# DATABASE_URL=postgres://aion:aion@localhost:5432/aion
# REDIS_URL=redis://localhost:6379

# --- Núcleo / agente ---
AION_MEMORY=data/memory.jsonl
AION_AUDIT=data/audit.jsonl
AION_LOG=info
# Modelo con visión para el comando `vision`:
AION_VISION_MODEL=huihui_ai/gemma-4-abliterated:12b
