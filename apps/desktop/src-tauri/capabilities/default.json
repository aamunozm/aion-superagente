{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos de AION: lanzar el núcleo y el control-plane como sidecars.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/aion-core", "sidecar": true, "args": true },
        { "name": "binaries/aion-control-plane", "sidecar": true, "args": true }
      ]
    }
  ]
}
