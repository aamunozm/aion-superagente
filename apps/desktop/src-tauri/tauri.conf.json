{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AION",
  "version": "0.0.1",
  "identifier": "it.prontoclick.aion",
  "build": {
    "beforeDevCommand": "pnpm --filter @aion/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "AION_TAURI=1 pnpm --filter @aion/web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "AION",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600,
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765 http://127.0.0.1:8787 https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/aion-core", "binaries/aion-control-plane"],
    "resources": { "ollama-runtime": "ollama-runtime/", "bootstrap": "bootstrap/" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
